{
  "name": "codecheck-inline",
  "displayName": "CodeCheck — AI Test Diagnostics",
  "publisher": "codecheck-dev",
  "version": "0.2.0",
  "description": "Inline diagnostics showing AI-generated test failures as red underlines. Works with CodeCheck's test generation engine.",
  "type": "module",
  "main": "./dist/extension.js",
  "types": "./dist/extension.d.ts",
  "exports": {
    ".": {
      "import": "./dist/extension.js",
      "types": "./dist/extension.d.ts"
    }
  },
  "files": ["dist"],
  "categories": ["Testing", "Linters"],
  "engines": {
    "vscode": "^1.80.0",
    "node": ">=18.0.0"
  },
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "commands": [
      {
        "command": "codecheck.refresh",
        "title": "CodeCheck: Refresh Diagnostics"
      },
      {
        "command": "codecheck.clear",
        "title": "CodeCheck: Clear Diagnostics"
      }
    ]
  },
  "scripts": {
    "build": "tsup src/extension.ts src/diagnostics.ts --format esm --dts --clean --external vscode",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codecheck/core": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.80.0",
    "tsup": "^8.5.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  },
  "license": "MIT",
  "author": { "name": "Medhavee Upadhyaya", "url": "https://github.com/medhavee" },
  "homepage": "https://github.com/medhavee-upadhyaya/codecheck#readme",
  "repository": { "type": "git", "url": "https://github.com/medhavee-upadhyaya/codecheck.git" },
  "bugs": { "url": "https://github.com/medhavee-upadhyaya/codecheck/issues" },
  "publishConfig": { "access": "public" },
  "keywords": ["codecheck", "vscode", "inline", "diagnostics", "testing", "ai"]
}
