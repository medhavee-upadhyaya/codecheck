{
  "name": "@codecheck/core",
  "version": "0.1.0",
  "description": "AI engine for CodeCheck — reads code, generates and runs tests automatically",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@typescript-eslint/typescript-estree": "^8.58.0",
    "cosmiconfig": "^9.0.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  },
  "license": "MIT",
  "author": {
    "name": "Medhavee Upadhyaya",
    "url": "https://github.com/medhavee"
  },
  "homepage": "https://github.com/medhavee/codecheck#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/medhavee/codecheck.git"
  },
  "bugs": {
    "url": "https://github.com/medhavee/codecheck/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "codecheck",
    "testing",
    "ai",
    "code-generation",
    "test-automation",
    "claude",
    "anthropic"
  ]
}
