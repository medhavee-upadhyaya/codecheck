{
  "name": "@codecheck/output-dashboard",
  "version": "0.2.0",
  "description": "CodeCheck output plugin — web dashboard showing test results with pass rates, history, and flakiness detection",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "codecheck-serve": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codecheck/core": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  },
  "license": "MIT",
  "author": {
    "name": "Medhavee Upadhyaya",
    "url": "https://github.com/medhavee"
  },
  "homepage": "https://github.com/medhavee-upadhyaya/codecheck#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/medhavee-upadhyaya/codecheck.git"
  },
  "bugs": {
    "url": "https://github.com/medhavee-upadhyaya/codecheck/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "codecheck",
    "testing",
    "dashboard",
    "web-ui",
    "ai"
  ]
}
