{
  "name": "@codecheck/trigger-onsave",
  "version": "0.1.0",
  "description": "CodeCheck trigger plugin — runs on file save via chokidar file watcher",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "codecheck-watch": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codecheck/core": "0.1.0",
    "@codecheck/output-terminal": "0.1.0",
    "@codecheck/scope-smoke": "0.1.0",
    "@codecheck/scope-unit": "0.1.0",
    "chalk": "^5.4.1",
    "chokidar": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  }
}
