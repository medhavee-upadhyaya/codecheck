{
  "name": "@codecheck/mcp-server",
  "version": "0.2.0",
  "description": "MCP server for CodeCheck — lets Claude Code and other AI assistants run AI-generated tests automatically",
  "type": "module",
  "bin": {
    "codecheck-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codecheck/core": "^0.2.0",
    "@codecheck/scope-api": "^0.2.0",
    "@codecheck/scope-e2e": "^0.2.0",
    "@codecheck/scope-functional": "^0.2.0",
    "@codecheck/scope-integration": "^0.2.0",
    "@codecheck/scope-regression": "^0.2.0",
    "@codecheck/scope-sanity": "^0.2.0",
    "@codecheck/scope-smoke": "^0.2.0",
    "@codecheck/scope-snapshot": "^0.2.0",
    "@codecheck/scope-unit": "^0.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.6.0"
  },
  "license": "MIT",
  "author": {
    "name": "Medhavee Upadhyaya",
    "url": "https://github.com/medhavee"
  },
  "homepage": "https://github.com/medhavee-upadhyaya/codecheck#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/medhavee-upadhyaya/codecheck.git"
  },
  "bugs": {
    "url": "https://github.com/medhavee-upadhyaya/codecheck/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "codecheck",
    "mcp",
    "mcp-server",
    "claude",
    "claude-code",
    "testing",
    "ai",
    "test-automation",
    "anthropic",
    "model-context-protocol"
  ]
}
